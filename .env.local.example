NEXTAUTH_URL=http://localhost:3005
AUTH_SECRET=<secret>
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/geosmartaudit
KEYCLOAK_CLIENT_ID=geo-fe
KEYCLOAK_CLIENT_SECRET=<secret>
NEXT_PUBLIC_KEYCLOAK_ISSUER=https://keycloak.example.com/realms/geosmartaudit
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=geo-fe
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
# WebSocket base URL for Socket.io gateway (namespace /runs).
# Defaults to NEXT_PUBLIC_API_BASE_URL with /api/v1 stripped (same origin).
# Override only if your WS server runs on a different host/port.
# NEXT_PUBLIC_WS_URL=http://localhost:3000
