# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3005
# Stringa random per firmare le sessioni NextAuth (va bene qualsiasi valore in locale)
AUTH_SECRET=dev-secret-local-only

# ── Keycloak (server-side NextAuth) ───────────────────────────────────────────
# Realm importato automaticamente da geo_be/keycloak/realm-export.json al primo avvio
KEYCLOAK_ISSUER=http://localhost:8080/realms/geosmartaudit
KEYCLOAK_CLIENT_ID=geo-fe
# Secret fisso definito in realm-export.json — non serve copiarlo da Keycloak UI
KEYCLOAK_CLIENT_SECRET=geo-fe-secret-local

# ── Keycloak (client-side) ────────────────────────────────────────────────────
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8080/realms/geosmartaudit
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=geo-fe

# ── API ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
# WebSocket gateway (Socket.io, namespace /runs) — stesso host del BE
NEXT_PUBLIC_WS_URL=http://localhost:3000
